#!/usr/bin/env bash

# SSH agent — only spawn one when there isn't already a live agent
# reachable via SSH_AUTH_SOCK. Without this guard, every new shell forks
# a fresh agent and the user accumulates orphans. ssh-add -l exits 0
# (agent has keys), 1 (agent reachable, no keys), or 2 (no agent).
ssh-add -l >/dev/null 2>&1
case $? in
  0|1) ;;
  *)   eval "$(ssh-agent -s)" >/dev/null ;;
esac

# nvm (Homebrew install)
if command -v brew >/dev/null 2>&1; then
  NVM_PREFIX="$(brew --prefix nvm 2>/dev/null || true)"
  if [ -n "$NVM_PREFIX" ] && [ -s "$NVM_PREFIX/nvm.sh" ]; then
    . "$NVM_PREFIX/nvm.sh"
    [ -s "$NVM_PREFIX/etc/bash_completion.d/nvm" ] && . "$NVM_PREFIX/etc/bash_completion.d/nvm"
  fi
  unset NVM_PREFIX
fi

# pyenv
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init --path)"
  eval "$(pyenv virtualenv-init -)"
fi

# rbenv
if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init -)"
fi
